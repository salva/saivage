{
  "name": "saivage",
  "version": "0.1.0",
  "description": "Self-extending autonomous AI agent",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "saivage": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:web && tsup",
    "build:web": "cd web && npm run build",
    "build:server": "tsup",
    "dev": "tsx src/server/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "docs:api": "typedoc && node docs/.vitepress/scripts/sanitize-typedoc.mjs",
    "docs:dev": "npm run docs:api && vitepress dev docs",
    "docs:build": "npm run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/static": "^9.1.0",
    "@fastify/websocket": "^11.2.0",
    "@mariozechner/pi-ai": "^0.72.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "fastify": "^5.8.4",
    "grammy": "^1.42.0",
    "openai": "^4.86.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/ws": "^8.18.1",
    "eslint": "^9.25.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "typescript": "^5.8.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.1.1"
  }
}
