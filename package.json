{
  "name": "saivage",
  "version": "0.1.0",
  "description": "Self-extending autonomous AI agent",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "saivage": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:web && tsup",
    "build:web": "cd web && npm run build",
    "build:server": "tsup",
    "dev": "tsx src/server/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/static": "^9.1.0",
    "@fastify/websocket": "^11.2.0",
    "@mariozechner/pi-ai": "^0.66.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.1",
    "cheerio": "^1.0.0",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "fastify": "^5.8.4",
    "grammy": "^1.42.0",
    "openai": "^4.86.2",
    "simple-git": "^3.27.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.1",
    "@types/ws": "^8.18.1",
    "eslint": "^9.25.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
