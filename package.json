{
  "name": "saivage",
  "version": "0.1.0",
  "description": "Self-extending autonomous AI agent",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "saivage": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:web && tsup",
    "build:web": "cd web && npm run build",
    "build:server": "tsup",
    "dev": "tsx src/server/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bundle": "npm run build && vitest run -t 'walkBuiltinSkills picks up bundled SKILL.md'",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "docs:api": "typedoc && node docs/.vitepress/scripts/sanitize-typedoc.mjs",
    "docs:dev": "npm run docs:api && vitepress dev docs",
    "docs:build": "npm run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@fastify/static": "^9.1.0",
    "@fastify/websocket": "^11.2.0",
    "@mariozechner/pi-ai": "^0.73.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^14.0.3",
    "fastify": "^5.8.4",
    "grammy": "^1.43.0",
    "he": "^1.2.0",
    "js-tiktoken": "^1.0.21",
    "node-html-parser": "^6.1.13",
    "openai": "^6.39.0",
    "telegramify-markdown": "^1.3.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "eslint": "^10.4.0",
    "happy-dom": "^20.9.0",
    "mermaid": "^11.15.0",
    "tsup": "^8.4.0",
    "tsx": "^4.22.3",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.7"
  }
}
